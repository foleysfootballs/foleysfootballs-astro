---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Tools" activePage="tools">

  <div class="section-label" style="margin-bottom: 20px;">Tools &amp; Calculators</div>

  <p style="font-size: 0.9rem; line-height: 1.7; color: var(--muted); max-width: 520px; margin-bottom: 28px;">
    Free tools built for football fans. No signup, no BS.
  </p>

  <div class="tools-grid">

    <a href="/tools/parlay" class="tool-card">
      <div class="tool-card-icon">&#x25C8;</div>
      <div class="tool-card-title">Parlay Calculator</div>
      <div class="tool-card-desc">
        Build 2&#x2013;7 leg parlays. Slide your bet size and target payout.
        Works in American or decimal odds. Instant results.
      </div>
      <div class="tool-card-link">Open Calculator &#x2192;</div>
    </a>

    <div class="tool-card tool-coming-soon">
      <div class="tool-card-icon">&#x25CE;</div>
      <div class="tool-card-title">Coming Soon</div>
      <div class="tool-card-desc">More football tools in the works. Check back soon.</div>
    </div>

    <div class="tool-card tool-coming-soon">
      <div class="tool-card-icon">&#x25F7;</div>
      <div class="tool-card-title">Coming Soon</div>
      <div class="tool-card-desc">More football tools in the works. Check back soon.</div>
    </div>

  </div>

</Layout>
