---
import Layout from '../../layouts/Layout.astro';
import { balls } from '../../data/balls.js';

export function getStaticPaths() {
  return balls.map(ball => ({
    params: { id: ball.id },
    props: { ball },
  }));
}

const { ball } = Astro.props;

function badgeClass(tagType) {
  const map = { special: 'badge-special', logo: 'badge-logo', standard: 'badge-standard', sold: 'badge-sold' };
  return map[tagType] || 'badge-standard';
}

function photoUrl(ball, photo) {
  if (typeof photo === 'string' && photo.startsWith('http')) return photo;
  return `/images/${ball.id}/${photo}`;
}
---

<Layout title={ball.title} activePage="store">

  <div class="detail-wrap">
    <a href="/store" class="detail-back">&#x2190; Back to Store</a>

    {ball.status === 'sold' ? (
      <!-- SOLD STATE -->
      <div style="background: var(--surface); border: 1px solid var(--border); border-left: 3px solid var(--green); padding: 20px 24px; margin-bottom: 28px; display: flex; align-items: center; gap: 14px;">
        <span style="font-size: 1.5rem;">&#x1F3C8;</span>
        <div>
          <div style="font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); margin-bottom: 4px;">This Ball Has Been Sold</div>
          <div style="font-size: 0.84rem; color: var(--muted);">Check the store for other available balls.</div>
        </div>
        <a href="/store" style="margin-left: auto; font-family: 'Barlow Condensed', sans-serif; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); text-decoration: none; white-space: nowrap;">Shop Now &#x2192;</a>
      </div>
    ) : null}

    <div class="detail-layout">

      <!-- GALLERY -->
      <div>
        {ball.photos.length > 0 ? (
          <>
            <img
              class="detail-main-img"
              id="detail-main-img"
              src={photoUrl(ball, ball.photos[0])}
              alt={ball.title}
              onclick="openLightbox(0)"
            />
            {ball.photos.length > 1 && (
              <div class="detail-thumbs">
                {ball.photos.map((photo, i) => (
                  <img
                    class={`detail-thumb ${i === 0 ? 'active' : ''}`}
                    src={photoUrl(ball, photo)}
                    alt={`Photo ${i + 1}`}
                    onclick={`switchThumb(this, '${photoUrl(ball, photo)}', ${i})`}
                    loading="lazy"
                  />
                ))}
              </div>
            )}
            <p style="font-size: 0.75rem; color: var(--faint); margin-top: 8px;">Click photo to enlarge &#x2022; {ball.photos.length} photo{ball.photos.length !== 1 ? 's' : ''}</p>
          </>
        ) : (
          <div class="detail-no-img">&#x1F3C8;</div>
        )}

        {ball.ebayId && (
          <a href={`https://www.ebay.com/itm/${ball.ebayId}`} target="_blank" style="display: inline-flex; align-items: center; gap: 6px; margin-top: 12px; font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue); text-decoration: none; opacity: 0.75;">
            View on eBay &#x2197; &nbsp;&#xB7;&nbsp; Item #{ball.ebayId}
          </a>
        )}
      </div>

      <!-- INFO -->
      <div class="detail-info">
        <div class="detail-eyebrow">Wilson The Duke &#xB7; NFL Game Ball</div>
        <h1 class="detail-title">{ball.title}</h1>
        <span class={`badge ${badgeClass(ball.tagType)}`} style="display: inline-block; margin-bottom: 16px;">{ball.tag}</span>

        {ball.status === 'active' ? (
          <>
            <div class="detail-price">${ball.price}</div>
            <div class="detail-price-note">+ $14 shipping &#xB7; Ships from Philadelphia, PA &#xB7; Usually 2 business days</div>
          </>
        ) : (
          <div class="detail-price" style="color: var(--muted);">${ball.price} <span style="font-size: 1rem; font-family: 'Barlow Condensed'; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green);">SOLD</span></div>
        )}

        <ul class="detail-specs">
          <li>Authentic Wilson &#x201C;The Duke&#x201D; &#x2014; official NFL game ball</li>
          <li>Hand-conditioned through professional multi-step process</li>
          <li>NFL-sourced &#xB7; PSA verified provenance</li>
          <li>Game-ready from day one &#x2014; no break-in needed</li>
          {ball.notes && <li>{ball.notes}</li>}
          <li>Ships within 2 business days from Philadelphia, PA</li>
        </ul>

        {ball.status === 'active' && (
          <div class="detail-actions">
            {ball.stripeUrl && (
              <a class="btn-buy-now" href={ball.stripeUrl} target="_blank">
                Buy Direct &#x2014; ${ball.price}
              </a>
            )}
            {ball.ebayId && (
              <a class="btn-ebay-out" href={`https://www.ebay.com/itm/${ball.ebayId}`} target="_blank">
                Buy on eBay &#x2197;
              </a>
            )}
            <a href={`/contact?topic=site&item=${ball.id}`} style="text-align: center; font-family: 'Barlow Condensed', sans-serif; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); text-decoration: none; padding: 8px 0;">
              Questions? Message us &#x2192;
            </a>
          </div>
        )}

        {ball.status === 'sold' && (
          <a href="/store" class="btn-buy-now">Browse Available Balls &#x2192;</a>
        )}

        <div class="psa-notice">
          <div class="psa-notice-label">About the PSA Authentication Sticker</div>
          <p>Many of our balls were originally sourced from the NFL with PSA-authenticated player signatures. The autograph has faded through conditioning &#x2014; you are purchasing a conditioned, game-ready football, not a signed collectible, priced accordingly.</p>
          <p>The PSA sticker stays on as our inventory tracking system &#x2014; it confirms this is a genuine NFL-sourced ball.</p>
        </div>
      </div>
    </div>
  </div>

</Layout>

<!-- LIGHTBOX -->
<div id="lightbox" onclick="closeLightbox(event)" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.93);align-items:center;justify-content:center;">
  <button onclick="closeLightboxBtn()" style="position:absolute;top:20px;right:24px;font-size:1.8rem;color:var(--cream);cursor:pointer;background:none;border:none;opacity:0.7;line-height:1;">&#x2715;</button>
  <button onclick="lightboxNav(-1)" style="position:absolute;top:50%;left:8px;transform:translateY(-50%);font-size:2.5rem;color:var(--cream);cursor:pointer;background:none;border:none;opacity:0.55;padding:16px;line-height:1;">&#8249;</button>
  <img id="lightbox-img" src="" alt="Ball photo" style="max-width:90vw;max-height:85vh;object-fit:contain;"/>
  <button onclick="lightboxNav(1)" style="position:absolute;top:50%;right:8px;transform:translateY(-50%);font-size:2.5rem;color:var(--cream);cursor:pointer;background:none;border:none;opacity:0.55;padding:16px;line-height:1;">&#8250;</button>
  <div id="lightbox-counter" style="position:absolute;bottom:20px;left:50%;transform:translateX(-50%);font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);"></div>
</div>

<script define:vars={{ photos: ball.photos, ballId: ball.id }}>
  const photoUrls = photos.map(p =>
    (typeof p === 'string' && p.startsWith('http')) ? p : `/images/${ballId}/${p}`
  );
  let lbIdx = 0;

  function openLightbox(idx) {
    if (!photoUrls.length) return;
    lbIdx = idx;
    document.getElementById('lightbox-img').src = photoUrls[lbIdx];
    document.getElementById('lightbox-counter').textContent = (lbIdx+1) + ' / ' + photoUrls.length;
    const lb = document.getElementById('lightbox');
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closeLightboxBtn() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
  }
  function closeLightbox(e) {
    if (e.target === document.getElementById('lightbox')) closeLightboxBtn();
  }
  function lightboxNav(dir) {
    lbIdx = (lbIdx + dir + photoUrls.length) % photoUrls.length;
    document.getElementById('lightbox-img').src = photoUrls[lbIdx];
    document.getElementById('lightbox-counter').textContent = (lbIdx+1) + ' / ' + photoUrls.length;
  }
  function switchThumb(el, src, idx) {
    document.getElementById('detail-main-img').src = src;
    document.querySelectorAll('.detail-thumb').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    lbIdx = idx;
  }
  document.addEventListener('keydown', e => {
    if (document.getElementById('lightbox').style.display !== 'flex') return;
    if (e.key === 'ArrowRight') lightboxNav(1);
    if (e.key === 'ArrowLeft') lightboxNav(-1);
    if (e.key === 'Escape') closeLightboxBtn();
  });

  window.openLightbox = openLightbox;
  window.closeLightbox = closeLightbox;
  window.closeLightboxBtn = closeLightboxBtn;
  window.lightboxNav = lightboxNav;
  window.switchThumb = switchThumb;
</script>
