---
import Layout from '../layouts/Layout.astro';
import { activeBalls, soldBalls, siteStats } from '../data/balls.js';

function badgeClass(tagType) {
  const map = { special: 'badge-special', logo: 'badge-logo', standard: 'badge-standard', sold: 'badge-sold' };
  return map[tagType] || 'badge-standard';
}

// Show first 8 active balls on homepage
const featuredBalls = activeBalls.slice(0, 8);
---

<Layout title="Game-Ready NFL Footballs" activePage="home">

  <!-- HERO -->
  <div class="hero-strip">
    <div>
      <div class="hero-eyebrow">NFL-Sourced &#xB7; PSA Authenticated &#xB7; PA Registered Business</div>
      <h1 class="hero-h1">Game-Ready<br><em>From Day One.</em></h1>
      <p class="hero-sub">Every Wilson &#x201C;The Duke&#x201D; we sell is hand-conditioned through a professional multi-step process. No break-in time. The real NFL experience, right out of the box.</p>
    </div>
    <div class="hero-stats">
      <div class="hstat">
        <div class="hstat-val">{siteStats.totalSold}</div>
        <div class="hstat-label">Sold</div>
      </div>
      <div class="hstat">
        <div class="hstat-val">{siteStats.feedbackCount}</div>
        <div class="hstat-label">Feedback</div>
      </div>
      <div class="hstat">
        <div class="hstat-val">{siteStats.feedbackPositive}</div>
        <div class="hstat-label">Positive</div>
      </div>
    </div>
  </div>

  <!-- MARQUEE -->
  <div class="marquee-wrap">
    <div class="marquee-inner">
      {[...Array(2)].map(() => (
        <>
          <span class="marquee-item">Authentic Wilson &#x201C;The Duke&#x201D;</span>
          <span class="marquee-item marquee-sep">&#x2726;</span>
          <span class="marquee-item">NFL-Sourced Inventory</span>
          <span class="marquee-item marquee-sep">&#x2726;</span>
          <span class="marquee-item">PSA Authenticated</span>
          <span class="marquee-item marquee-sep">&#x2726;</span>
          <span class="marquee-item">Hand-Conditioned</span>
          <span class="marquee-item marquee-sep">&#x2726;</span>
          <span class="marquee-item">{siteStats.feedbackCount} Five-Star Reviews</span>
          <span class="marquee-item marquee-sep">&#x2726;</span>
          <span class="marquee-item">{siteStats.totalSold} Sold</span>
          <span class="marquee-item marquee-sep">&#x2726;</span>
          <span class="marquee-item">Registered PA Business</span>
          <span class="marquee-item marquee-sep">&#x2726;</span>
        </>
      ))}
    </div>
  </div>

  <!-- ACTIVE LISTINGS -->
  <div class="section-label">
    Available Now &#x2014; {activeBalls.length} Ball{activeBalls.length !== 1 ? 's' : ''}
    <a href="/store">View all &#x2192;</a>
  </div>

  <div class="tile-grid">
    {featuredBalls.map(ball => (
      <a href={`/balls/${ball.id}`} class="tile">
        <div class="tile-img-wrap">
          {ball.photos.length > 0
            ? <img src={typeof ball.photos[0] === 'string' && ball.photos[0].startsWith('http')
                ? ball.photos[0]
                : `/images/${ball.id}/${ball.photos[0]}`}
                alt={ball.title} loading="lazy"/>
            : <div class="tile-no-img">&#x1F3C8;</div>
          }
        </div>
        <div class="tile-type-row">
          <span style="color: var(--blue); font-family: 'Barlow Condensed'; font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;">
            {ball.ebayId ? 'eBay + Direct' : 'Site Only'}
          </span>
          <span class={`badge ${badgeClass(ball.tagType)}`}>{ball.tag}</span>
        </div>
        <div class="tile-body">
          <div class="tile-title">{ball.title}</div>
          <div class="tile-note">{ball.notes.length > 65 ? ball.notes.slice(0, 65) + '...' : ball.notes}</div>
        </div>
        {ball.ebayId && ball.stripeUrl ? (
          <div class="tile-footer">
            <span class="tile-btn tile-btn-ebay" onclick={`event.preventDefault(); window.open('https://www.ebay.com/itm/${ball.ebayId}', '_blank')`}>
              Buy on eBay &#x2197;
            </span>
            <span class="tile-btn tile-btn-stripe" onclick={`event.preventDefault(); window.open('${ball.stripeUrl}', '_blank')`}>
              Buy Direct &#x2193;
            </span>
          </div>
        ) : ball.stripeUrl ? (
          <div class="tile-footer" style="grid-template-columns: 1fr;">
            <span class="tile-btn tile-btn-stripe" onclick={`event.preventDefault(); window.open('${ball.stripeUrl}', '_blank')`}>
              Buy Now &#x2192;
            </span>
          </div>
        ) : null}
        <div class="tile-price-row">${ball.price}</div>
      </a>
    ))}

    <!-- INVENTORY TRACKER TILE -->
    <div class="tile tile-special">
      <div class="tile-type-row">
        <span style="color: var(--muted); font-family: 'Barlow Condensed'; font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;">Live Inventory</span>
      </div>
      <div style="font-family: 'Bebas Neue', sans-serif; font-size: 1.1rem; color: var(--cream); padding: 10px 12px 4px; line-height: 1;">Stock Tracker</div>
      <div class="tracker-row"><span class="tracker-label">Active Listings</span><span class="tracker-val">{activeBalls.length}</span></div>
      <div class="tracker-row"><span class="tracker-label">Total Sold</span><span class="tracker-val green">{siteStats.totalSold}</span></div>
      <div class="tracker-row"><span class="tracker-label">eBay Feedback</span><span class="tracker-val">{siteStats.feedbackCount}</span></div>
      <div class="tracker-row"><span class="tracker-label">Positive Rating</span><span class="tracker-val">{siteStats.feedbackPositive}</span></div>
    </div>

    <!-- REVIEW TILE -->
    <a href="/reviews" class="tile tile-special" style="text-decoration: none; color: inherit; cursor: pointer;">
      <div class="tile-type-row">
        <span style="color: var(--muted); font-family: 'Barlow Condensed'; font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;">Reviews</span>
        <span style="color: var(--gold); font-size: 11px; letter-spacing: 2px;">&#x2605;&#x2605;&#x2605;&#x2605;&#x2605;</span>
      </div>
      <div style="padding: 10px 12px;">
        <p style="font-size: 0.82rem; line-height: 1.6; color: var(--muted); font-style: italic; margin-bottom: 10px;">&#x201C;Shipped immediately, well packaged. Item as described perfectly!! Love my football.&#x201D;</p>
        <div style="font-family: 'Barlow Condensed', sans-serif; font-size: 9px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--leather);">y***s &#xB7; eBay Verified</div>
      </div>
      <div class="tile-price-row" style="color: var(--muted); font-size: 0.75rem; font-family: 'Barlow Condensed';">
        {siteStats.feedbackCount} feedback &#xB7; See all reviews &#x2192;
      </div>
    </a>

    <!-- EMAIL SIGNUP TILE -->
    <div class="tile tile-special">
      <div class="tile-type-row">
        <span style="color: var(--muted); font-family: 'Barlow Condensed'; font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;">Stay in the Loop</span>
      </div>
      <div style="padding: 8px 12px 12px;">
        <p style="font-size: 0.8rem; color: var(--muted); line-height: 1.5; margin-bottom: 10px;">New drops, exclusive discounts, and tools.</p>
        <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" style="display: flex; flex-direction: column; gap: 6px;">
          <input type="email" name="email" placeholder="your@email.com" style="width: 100%; background: var(--bg); border: 1px solid rgba(245,239,230,0.12); color: var(--text); font-family: 'Barlow', sans-serif; font-size: 0.82rem; padding: 8px 10px; outline: none;"/>
          <button type="submit" style="width: 100%; background: var(--gold); color: #0F0A05; border: none; padding: 8px; font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer;">Subscribe &#x2192;</button>
        </form>
      </div>
    </div>

    <!-- PARLAY TOOL TILE -->
    <a href="/tools/parlay" class="tile tile-special" style="text-decoration: none; color: inherit; cursor: pointer;">
      <div class="tile-type-row">
        <span style="color: var(--muted); font-family: 'Barlow Condensed'; font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;">Free Tool</span>
      </div>
      <div style="padding: 10px 12px 14px;">
        <div style="font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 1rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--cream); margin-bottom: 6px;">Parlay Calculator</div>
        <p style="font-size: 0.8rem; color: var(--muted); line-height: 1.5; margin-bottom: 10px;">Build 2&#x2013;7 leg parlays. Slide bet size and target payout. American or decimal odds.</p>
        <span style="font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold);">Try it &#x2192;</span>
      </div>
    </a>
  </div>

  <!-- SOLD SECTION -->
  {soldBalls.length > 0 && (
    <>
      <div class="section-label" style="margin-top: 12px;">
        Recently Sold
        <span style="font-size: 0.65rem; color: var(--muted);">{soldBalls.length} ball{soldBalls.length !== 1 ? 's' : ''}</span>
      </div>
      <div class="tile-grid" style="opacity: 0.7;">
        {soldBalls.map(ball => (
          <div class="tile tile-sold">
            <div class="tile-img-wrap sold-wrap">
              {ball.photos.length > 0
                ? <img class="sold-img" src={typeof ball.photos[0] === 'string' && ball.photos[0].startsWith('http')
                    ? ball.photos[0]
                    : `/images/${ball.id}/${ball.photos[0]}`}
                    alt="sold" loading="lazy"/>
                : <div class="tile-no-img">&#x1F3C8;</div>
              }
              <div class="sold-stamp">SOLD</div>
            </div>
            <div class="tile-type-row">
              <span style="color: var(--muted); font-family: 'Barlow Condensed'; font-size: 9px;">{ball.tag}</span>
              <span class="badge badge-sold">Sold</span>
            </div>
            <div class="tile-body">
              <div class="tile-title" style="color: var(--muted);">{ball.title}</div>
              <div class="tile-note">No longer available</div>
            </div>
            <div class="tile-price-row" style="color: var(--muted);">${ball.price}</div>
          </div>
        ))}
      </div>
    </>
  )}

</Layout>
